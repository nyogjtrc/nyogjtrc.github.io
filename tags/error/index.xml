&lt;li&gt;&lt;a href=&#34;https://medium.com/@sebdah/go-best-practices-error-handling-2d15e1f0c5ee&#34;&gt;https://medium.com/@sebdah/go-best-practices-error-handling-2d15e1f0c5ee&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
</description>
